# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key - used for cron jobs and admin operations
# ⚠️  KEEP SECRET - Never expose in client-side code
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ============================================================================
# CRON JOB CONFIGURATION
# ============================================================================

# Secret key for manually triggering cron jobs
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=generate-a-32-character-secret-key-here

# Enable/disable automatic photo rotation
# Default: true
CRON_PHOTO_ROTATION_ENABLED=true

# Enable/disable cron notifications
# Default: true
CRON_NOTIFICATIONS_ENABLED=true

# Logging level: debug, info, warn, error
# Default: info
CRON_LOG_LEVEL=info

# ============================================================================
# PHOTO ROTATION SETTINGS
# ============================================================================

# Rotation frequency in hours
# Default: 72 (every 3 days)
# Options: 1, 6, 12, 24, 48, 72, 168
CRON_ROTATION_FREQUENCY_HOURS=72

# Days to look back for approved photos
# Default: 30
CRON_APPROVAL_WINDOW_DAYS=30

# Number of top photos to randomly select from
# Default: 10
CRON_TOP_PHOTOS_COUNT=10

# Minimum approved photos required before attempting rotation
# Default: 1
CRON_MIN_PHOTOS_REQUIRED=1

# ============================================================================
# STORAGE CONFIGURATION
# ============================================================================

# Supabase storage bucket for site photos
# Default: site-photos
NEXT_PUBLIC_STORAGE_BUCKET=site-photos

# Maximum photo size (in bytes)
# Default: 5242880 (5MB)
MAX_PHOTO_SIZE=5242880

# ============================================================================
# ADMIN CONFIGURATION
# ============================================================================

# Admin email(s) for notifications
# Comma-separated list
ADMIN_EMAILS=admin@example.com,moderator@example.com

# ============================================================================
# NOTIFICATION SETTINGS (Optional)
# ============================================================================

# Slack webhook for notifications
# If set, enables Slack notifications for rotation events
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# Discord webhook for notifications
# If set, enables Discord notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR/WEBHOOK

# Email notifications
# Requires email service setup
ENABLE_EMAIL_NOTIFICATIONS=false
EMAIL_SERVICE_PROVIDER=sendgrid
SENDGRID_API_KEY=your-sendgrid-key

# ============================================================================
# ANALYTICS (Optional)
# ============================================================================

# Analytics service for tracking rotations
ANALYTICS_ENABLED=false
ANALYTICS_SERVICE=mixpanel
MIXPANEL_TOKEN=your-mixpanel-token

# ============================================================================
# DEVELOPMENT/DEBUG
# ============================================================================

# Enable verbose logging
DEBUG_CRON=false

# Enable verbose photo scoring (shows individual scores)
DEBUG_PHOTO_SCORING=false

# Log individual site rotations
LOG_INDIVIDUAL_ROTATIONS=true

# ============================================================================
# NODE ENVIRONMENT
# ============================================================================

NODE_ENV=production
# Options: development, production

# ============================================================================
# DEPLOYMENT
# ============================================================================

# Vercel environment
VERCEL_ENV=production
# Options: development, preview, production

# Project name (for logging)
PROJECT_NAME=DIVE_DROP

# Version
APP_VERSION=1.0.0
